/*
 * DTS fragment for RK3566 NPU support (non-IOMMU mode).
 *
 * This file documents the minimal device tree additions required
 * by the rknpu out-of-tree kernel module. Since mainline DTBs lack
 * a __symbols__ node, standard DT overlays with phandle references
 * (&cru, &power, etc.) cannot be used. The nodes below must be
 * merged into the board DTB manually via decompile/edit/recompile.
 *
 * Usage:
 *   1. Copy the DTB from the device and decompile:
 *        ssh root@<device> "cat /boot/dtb/rockchip/<board>.dtb" > /tmp/device.dtb
 *        dtc -I dtb -O dts /tmp/device.dtb > /tmp/device.dts
 *
 *   2. Apply the four changes described below to /tmp/device.dts.
 *      All phandle values are board-specific — look them up in the
 *      decompiled DTS before editing.
 *
 *   3. Recompile and deploy:
 *        dtc -I dts -O dtb -o /tmp/device-modified.dtb /tmp/device.dts
 *        cat /tmp/device-modified.dtb | ssh root@<device> \
 *            "cat > /boot/dtb/rockchip/<board>.dtb"
 *
 * Required phandle references (values shown for OrangePi 3B v1.1):
 *
 *   Label               Node path                       phandle
 *   ─────────────────── ─────────────────────────────── ───────
 *   cru                 /clock-controller@fdd20000       0x0f
 *   scmi_clk            /firmware/scmi/protocol@14       0x02
 *   power               /power-controller                0x11
 *   qos_npu             /qos@fe180000                    0xfc
 *   vdd_npu (DCDC_REG4) /pmic@20/regulators/DCDC_REG4   0xdc
 */

/* ──────────────────────────────────────────────────────────────
 * 1. Add NPU power domain (PD_NPU = 6)
 *
 * Insert inside the "power-controller" node, before power-domain@7.
 *
 * Clock IDs (from rk3568-cru.h):
 *   ACLK_NPU_PRE = 39 (0x27)
 *   HCLK_NPU_PRE = 37 (0x25)
 *   PCLK_NPU_PRE = 38 (0x26)
 * ────────────────────────────────────────────────────────────── */

/*
power-domain@6 {
    reg = <0x06>;
    clocks = <&cru ACLK_NPU_PRE &cru HCLK_NPU_PRE &cru PCLK_NPU_PRE>;
    pm_qos = <&qos_npu>;
    #power-domain-cells = <0x00>;
};
*/

/* Numeric-phandle form (OrangePi 3B):

power-domain@6 {
    reg = <0x06>;
    clocks = <0x0f 0x27 0x0f 0x25 0x0f 0x26>;
    pm_qos = <0xfc>;
    #power-domain-cells = <0x00>;
};

*/

/* ──────────────────────────────────────────────────────────────
 * 2. Add NPU device node
 *
 * Insert as a top-level node (e.g. before gpu@fde60000).
 *
 * Clock IDs (from rk3568-cru.h):
 *   CLK_NPU   = 35 (0x23)
 *   ACLK_NPU  = 40 (0x28)
 *   HCLK_NPU  = 41 (0x29)
 *   SCMI_CLK_NPU = 2
 *
 * Reset IDs:
 *   SRST_A_NPU = 43 (0x2b)
 *   SRST_H_NPU = 44 (0x2c)
 *
 * assigned-clock-rates: 600 MHz = 0x23c34600
 * ────────────────────────────────────────────────────────────── */

/*
npu@fde40000 {
    compatible = "rockchip,rk3568-rknpu", "rockchip,rknpu";
    reg = <0x00 0xfde40000 0x00 0x10000>;
    interrupts = <GIC_SPI 151 IRQ_TYPE_LEVEL_HIGH>;
    interrupt-names = "npu_irq";
    clocks = <&scmi_clk SCMI_CLK_NPU &cru CLK_NPU &cru ACLK_NPU &cru HCLK_NPU>;
    clock-names = "scmi_clk", "clk", "aclk", "hclk";
    assigned-clocks = <&cru CLK_NPU>;
    assigned-clock-rates = <600000000>;
    resets = <&cru SRST_A_NPU &cru SRST_H_NPU>;
    reset-names = "srst_a", "srst_h";
    power-domains = <&power RK3568_PD_NPU>;
    rknpu-supply = <&vdd_npu>;
    status = "okay";
};
*/

/* Numeric-phandle form (OrangePi 3B):

npu@fde40000 {
    compatible = "rockchip,rk3568-rknpu", "rockchip,rknpu";
    reg = <0x00 0xfde40000 0x00 0x10000>;
    interrupts = <0x00 0x97 0x04>;
    interrupt-names = "npu_irq";
    clocks = <0x02 0x02 0x0f 0x23 0x0f 0x28 0x0f 0x29>;
    clock-names = "scmi_clk", "clk", "aclk", "hclk";
    assigned-clocks = <0x0f 0x23>;
    assigned-clock-rates = <0x23c34600>;
    resets = <0x0f 0x2b 0x0f 0x2c>;
    reset-names = "srst_a", "srst_h";
    power-domains = <0x11 0x06>;
    rknpu-supply = <0xdc>;
    status = "okay";
};

*/

/* ──────────────────────────────────────────────────────────────
 * 3. Add NPU IOMMU node (disabled — kept for future use)
 *
 * The rknpu driver v0.9.8 has IOMMU/IOVA management code that
 * is incompatible with mainline 6.19's iommu-dma subsystem,
 * causing bus errors. Keep IOMMU disabled until the driver is
 * patched to use public iommu_map/iommu_unmap APIs.
 *
 * Insert as a top-level node, adjacent to the NPU node.
 * ────────────────────────────────────────────────────────────── */

/*
iommu@fde4b000 {
    compatible = "rockchip,rk3568-iommu";
    reg = <0x00 0xfde4b000 0x00 0x40>;
    interrupts = <GIC_SPI 151 IRQ_TYPE_LEVEL_HIGH>;
    interrupt-names = "rknpu_mmu";
    clocks = <&cru ACLK_NPU &cru HCLK_NPU>;
    clock-names = "aclk", "iface";
    power-domains = <&power RK3568_PD_NPU>;
    #iommu-cells = <0x00>;
    status = "disabled";
};
*/

/* Numeric-phandle form (OrangePi 3B):

iommu@fde4b000 {
    compatible = "rockchip,rk3568-iommu";
    reg = <0x00 0xfde4b000 0x00 0x40>;
    interrupts = <0x00 0x97 0x04>;
    interrupt-names = "rknpu_mmu";
    clocks = <0x0f 0x28 0x0f 0x29>;
    clock-names = "aclk", "iface";
    power-domains = <0x11 0x06>;
    #iommu-cells = <0x00>;
    status = "disabled";
};

*/

/* ──────────────────────────────────────────────────────────────
 * 4. Prevent vdd_npu regulator from being disabled
 *
 * Add "regulator-always-on;" to the DCDC_REG4 node (vdd_npu).
 * Without this, the kernel regulator framework disables vdd_npu
 * after boot (as no consumer claims it early enough), causing
 * the NPU power domain to fail with -ETIMEDOUT.
 *
 * Find the DCDC_REG4 node in the PMIC section and add the
 * property right after its opening brace.
 * ────────────────────────────────────────────────────────────── */

/*
DCDC_REG4 {
    regulator-always-on;   // <-- add this line
    ...existing properties...
};
*/
